# App
APP_ENV=development
DEBUG=true
KIRIMI_BASE_URL=

KIRIMI_ID_API_KEY=
KIRIMI_DEVICE_ID=
KIRIMI_USER_CODE=
WA_BOT_NUMBER=

# Celery + Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://jagawarga:password@localhost:5432/jagawarga

# IndoBERT
CLASSIFIER_MODEL_PATH=./models/indobert-intent
CLASSIFIER_CONFIDENCE_THRESHOLD=0.65
CLASSIFIER_DROP_THRESHOLD=0.80

# LLM
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT=30

#Added for agent penipuan
LLM_MAX_TOKENS=4096

# Semantic dedup
DEDUP_SIMILARITY_THRESHOLD=0.90
DEDUP_CACHE_TTL=604800

# OCR
OCR_PROVIDER=llm

# External (agent_penipuan)
VIRUSTOTAL_API_KEY=

SERPAPI_KEY=

# Agent Penipuan URL checker
URL_CHECK_BROWSER=firefox
URL_CHECK_HEADLESS=true
URL_CHECK_TIMEOUT_MS=15000
URL_CHECK_MAX_TEXT_CHARS=6000
URL_CHECK_USE_LLM=true
